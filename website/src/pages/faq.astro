---
import BaseLayout from '../layouts/BaseLayout.astro';
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {"@type":"Question","name":"Will AdBunny conflict with my existing ad stack?","acceptedAnswer":{"@type":"Answer","text":"No. AdBunny is designed to run on remnant inventory only — the impressions your existing direct deals or header bidding partners don't fill — so it doesn't compete with your primary demand."}},
    {"@type":"Question","name":"How long does integration take?","acceptedAnswer":{"@type":"Answer","text":"Typically minutes. It's a single JS tag, not a waterfall setup or SDK integration, so there's minimal engineering lift."}},
    {"@type":"Question","name":"Do I need to configure anything after installing the tag?","acceptedAnswer":{"@type":"Answer","text":"No manual configuration is required. The AI optimization layer selects the best-paying banner per impression automatically."}},
    {"@type":"Question","name":"What ad formats does AdBunny support?","acceptedAnswer":{"@type":"Answer","text":"Banner formats across standard IAB sizes. Contact our team to confirm exact supported sizes for your integration."}},
    {"@type":"Question","name":"Is AdBunny suitable for small publishers, or only large ones?","acceptedAnswer":{"@type":"Answer","text":"Both. Because setup is a single tag with no ad-ops overhead, it works for independent sites as well as larger publishers looking to optimize remnant yield."}},
    {"@type":"Question","name":"How does AdBunny's AI decide which banner to serve?","acceptedAnswer":{"@type":"Answer","text":"For each impression, the optimization layer evaluates available demand in real time and selects the option likely to generate the highest revenue for that specific impression, rather than following a fixed, static order."}},
    {"@type":"Question","name":"Can ad networks or media buyers get access to AdBunny's inventory?","acceptedAnswer":{"@type":"Answer","text":"Yes — AdBunny offers programmatic access to aggregated remnant banner inventory for ad networks, DSPs, and media buyers."}}
  ]
};
---

<BaseLayout
  title="AdBunny FAQ — Banner Monetization Questions Answered"
  description="Answers to common questions about AdBunny's AI banner monetization platform, integration, and how it works alongside your existing ad stack."
  keywords="ad monetization platform FAQ, remnant inventory questions, ad tag integration FAQ"
>

<section class="pt-28 pb-20 max-md:pt-20 max-md:pb-14">
  <div class="max-w-[44rem] mx-auto px-8">
    <h1 class="font-extrabold leading-[1.05] tracking-tight mb-10" style="font-size:clamp(2.25rem,5vw,3.5rem)">Frequently asked questions</h1>
    <h2 class="sr-only">Common questions</h2>
    <div>
      <div style="border-bottom:1px solid var(--color-border)">
        <button class="faq-q w-full text-left bg-transparent border-none py-5 text-[0.9375rem] font-semibold cursor-pointer flex justify-between items-center gap-4" style="color:var(--color-text)">Will AdBunny conflict with my existing ad stack?</button>
        <div class="faq-a overflow-hidden transition-[max-height] duration-300 ease" style="max-height:0"><div class="pb-5 text-[0.9375rem] leading-relaxed" style="color:var(--color-text-secondary)">No. AdBunny is designed to run on remnant inventory only — the impressions your existing direct deals or header bidding partners don't fill — so it doesn't compete with your primary demand.</div></div>
      </div>
      <div style="border-bottom:1px solid var(--color-border)">
        <button class="faq-q w-full text-left bg-transparent border-none py-5 text-[0.9375rem] font-semibold cursor-pointer flex justify-between items-center gap-4" style="color:var(--color-text)">How long does integration take?</button>
        <div class="faq-a overflow-hidden transition-[max-height] duration-300 ease" style="max-height:0"><div class="pb-5 text-[0.9375rem] leading-relaxed" style="color:var(--color-text-secondary)">Typically minutes. It's a single JS tag, not a waterfall setup or SDK integration, so there's minimal engineering lift.</div></div>
      </div>
      <div style="border-bottom:1px solid var(--color-border)">
        <button class="faq-q w-full text-left bg-transparent border-none py-5 text-[0.9375rem] font-semibold cursor-pointer flex justify-between items-center gap-4" style="color:var(--color-text)">Do I need to configure anything after installing the tag?</button>
        <div class="faq-a overflow-hidden transition-[max-height] duration-300 ease" style="max-height:0"><div class="pb-5 text-[0.9375rem] leading-relaxed" style="color:var(--color-text-secondary)">No manual configuration is required. The AI optimization layer selects the best-paying banner per impression automatically.</div></div>
      </div>
      <div style="border-bottom:1px solid var(--color-border)">
        <button class="faq-q w-full text-left bg-transparent border-none py-5 text-[0.9375rem] font-semibold cursor-pointer flex justify-between items-center gap-4" style="color:var(--color-text)">What ad formats does AdBunny support?</button>
        <div class="faq-a overflow-hidden transition-[max-height] duration-300 ease" style="max-height:0"><div class="pb-5 text-[0.9375rem] leading-relaxed" style="color:var(--color-text-secondary)">Banner formats across standard IAB sizes. Contact our team to confirm exact supported sizes for your integration.</div></div>
      </div>
      <div style="border-bottom:1px solid var(--color-border)">
        <button class="faq-q w-full text-left bg-transparent border-none py-5 text-[0.9375rem] font-semibold cursor-pointer flex justify-between items-center gap-4" style="color:var(--color-text)">Is AdBunny suitable for small publishers, or only large ones?</button>
        <div class="faq-a overflow-hidden transition-[max-height] duration-300 ease" style="max-height:0"><div class="pb-5 text-[0.9375rem] leading-relaxed" style="color:var(--color-text-secondary)">Both. Because setup is a single tag with no ad-ops overhead, it works for independent sites as well as larger publishers looking to optimize remnant yield.</div></div>
      </div>
      <div style="border-bottom:1px solid var(--color-border)">
        <button class="faq-q w-full text-left bg-transparent border-none py-5 text-[0.9375rem] font-semibold cursor-pointer flex justify-between items-center gap-4" style="color:var(--color-text)">How does AdBunny's AI decide which banner to serve?</button>
        <div class="faq-a overflow-hidden transition-[max-height] duration-300 ease" style="max-height:0"><div class="pb-5 text-[0.9375rem] leading-relaxed" style="color:var(--color-text-secondary)">For each impression, the optimization layer evaluates available demand in real time and selects the option likely to generate the highest revenue for that specific impression, rather than following a fixed, static order.</div></div>
      </div>
      <div style="border-bottom:1px solid var(--color-border)">
        <button class="faq-q w-full text-left bg-transparent border-none py-5 text-[0.9375rem] font-semibold cursor-pointer flex justify-between items-center gap-4" style="color:var(--color-text)">Can ad networks or media buyers get access to AdBunny's inventory?</button>
        <div class="faq-a overflow-hidden transition-[max-height] duration-300 ease" style="max-height:0"><div class="pb-5 text-[0.9375rem] leading-relaxed" style="color:var(--color-text-secondary)">Yes — AdBunny offers programmatic access to aggregated remnant banner inventory for ad networks, DSPs, and media buyers. <a href="/advertisers" style="color:var(--color-text-secondary)">See our Advertisers page</a>.</div></div>
      </div>
    </div>
  </div>
</section>

<section class="pb-20 text-center">
  <a href="/get-started" class="btn btn-primary">Get Your JS Tag</a>
</section>

<script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)}></script>
</BaseLayout>
